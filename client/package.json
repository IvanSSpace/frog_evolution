{
  "name": "react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "prepare": "husky || true",
    "verify-uniqueness": "node scripts/verify_anim_uniqueness_strict.cjs && node scripts/verify_texture_uniqueness.cjs && node scripts/verify_sound_uniqueness.cjs",
    "sim-balance": "node scripts/simulate_balance.cjs",
    "check-translations": "node scripts/check-translations.cjs",
    "check-bundle": "node scripts/check-bundle-delta.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.6",
    "@tanstack/react-virtual": "^3.13.24",
    "axios": "^1.7.7",
    "husky": "^9.1.7",
    "i18next": "^26.0.8",
    "mitt": "^3.0.1",
    "phaser": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.6",
    "react-modal": "^3.16.1",
    "tailwindcss": "^3.4.15",
    "tone": "^15.1.22",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.6",
    "globals": "^15.12.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.2.0",
    "vitest": "^4.1.5"
  }
}
