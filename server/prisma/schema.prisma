generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique @map("telegram_id")
  username   String?
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  photoUrl   String?  @map("photo_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  banned     Boolean  @default(false)
  devFlags  String[] @default([]) @map("dev_flags")

  gameState   GameState?
  pityState   PityState?
  expeditions Expedition[]
  clanMembership   ClanMember?
  clanCooldown     UserClanCooldown?
  clanMessages     ClanMessage[]

  @@map("users")
}

// Cloud snapshot — клиент пишет туда полное состояние (gold, upgrades, frogs).
// Не source of truth для критичных операций — только для cross-device sync.
model GameState {
  id     Int @id @default(autoincrement())
  userId Int @unique @map("user_id")

  gold             BigInt   @default(0)
  upgrades         Json     @default("{\"dropSpeed\":0,\"tractor\":0,\"magnet\":0,\"crateQuality\":0,\"rareBoxSpeed\":0}")
  frogPurchases    Json     @default("[]")
  discoveredLevels Json     @default("[1]")
  magnetEnabled    Boolean  @default(true) @map("magnet_enabled")
  currentLocation  Int      @default(1) @map("current_location")
  locationFrogs    Json     @default("[[1],[],[]]") @map("location_frogs")
  cosmic           Json? // serums/boxes/ship/carriers/bestiary — лениво (JSONB)
  onboarding       Json? // welcomeSeen/firstBoxTapSeen/firstMergeSeen/locationsCelebrated
  boxOpenCount     Int      @default(0) @map("box_open_count")
  incomePerSec     Float    @default(0) @map("income_per_sec")
  version          Int      @default(0)
  lastSessionAt    DateTime @default(now()) @map("last_session_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("game_states")
}

// Server-authoritative pity-state для роллов rarity на сервере.
// Изолирован от GameState — обновляется через action endpoint'ы (box open),
// клиент не пишет туда напрямую.
model PityState {
  id     Int @id @default(autoincrement())
  userId Int @unique @map("user_id")

  rare      Int @default(0)
  epic      Int @default(0)
  legendary Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pity_states")
}

// Server-authoritative space expedition (Fallout Shelter-style).
// The journal + loot are NOT stored — they are a pure function of
// (seed, elapsed travel time, content version), recomputed on read.
// See src/expedition/.
enum ExpeditionStatus {
  OUTBOUND // ship traveling away, accruing log + loot
  RETURNING // recalled; flying home (return = outbound / 3)
  CLAIMED // docked, loot collected — terminal
  LOST // recalled too late, catastrophe — terminal, no loot
}

model Expedition {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")

  seed            Int // PRNG seed; full journey replays from this
  status          ExpeditionStatus @default(OUTBOUND)
  startedAt       DateTime         @default(now()) @map("started_at")
  recalledAt      DateTime?        @map("recalled_at")
  arrivalAt       DateTime?        @map("arrival_at")
  claimedAt       DateTime?        @map("claimed_at")
  tickIntervalSec Int              @default(60) @map("tick_interval_sec")
  shipStats       Json?            @map("ship_stats") // speed/luck/cargo/hull

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("expeditions")
}

model Clan {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  emblemIcon      String   @map("emblem_icon")
  emblemColor     String   @map("emblem_color")
  minEssence      Int      @default(0) @map("min_essence")
  leaderId        Int      @map("leader_id")
  createdAt       DateTime @default(now()) @map("created_at")
  lastActivityAt  DateTime @default(now()) @map("last_activity_at")

  members  ClanMember[]
  messages ClanMessage[]
  requests ClanRequest[]
  pins     ClanPin[]

  @@index([lastActivityAt])
  @@map("clans")
}

enum ClanRole {
  LEADER
  COLEADER
  MEMBER
}

model ClanMember {
  id       Int      @id @default(autoincrement())
  clanId   Int      @map("clan_id")
  userId   Int      @unique @map("user_id")
  role     ClanRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clanId])
  @@map("clan_members")
}

model ClanMessage {
  id        Int      @id @default(autoincrement())
  clanId    Int      @map("clan_id")
  userId    Int      @map("user_id")
  text      String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clanId, createdAt])
  @@map("clan_messages")
}

enum ClanRequestType {
  SLIME
  ESSENCE
  SERUM
}

model ClanRequest {
  id            Int             @id @default(autoincrement())
  clanId        Int             @map("clan_id")
  requesterId   Int             @map("requester_id")
  type          ClanRequestType
  element       String?
  targetAmount  BigInt          @map("target_amount")
  currentAmount BigInt          @default(0) @map("current_amount")
  completed     Boolean         @default(false)
  createdAt     DateTime        @default(now()) @map("created_at")
  expiresAt     DateTime        @map("expires_at")

  clan      Clan            @relation(fields: [clanId], references: [id], onDelete: Cascade)
  donations ClanDonation[]

  @@index([clanId, createdAt])
  @@index([expiresAt])
  @@map("clan_requests")
}

model ClanDonation {
  id         Int      @id @default(autoincrement())
  requestId  Int      @map("request_id")
  donorId    Int      @map("donor_id")
  amount     BigInt
  createdAt  DateTime @default(now()) @map("created_at")

  request ClanRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("clan_donations")
}

model ClanPin {
  id          Int      @id @default(autoincrement())
  clanId      Int      @map("clan_id")
  authorId    Int      @map("author_id")
  text        String   @db.VarChar(300)
  missionRef  String?  @map("mission_ref")
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@index([clanId, expiresAt])
  @@map("clan_pins")
}

model UserClanCooldown {
  userId Int      @id @map("user_id")
  until  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_clan_cooldowns")
}
