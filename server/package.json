{
  "name": "frog-evolution-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch 'src/' --ext ts --exec 'npm run build && node dist/src/index.js'",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "clean": "rm -rf dist",
    "prisma:add-migration": "npx prisma migrate dev --name",
    "prisma:generate": "npx prisma generate",
    "local:db": "docker compose -f docker-compose.local.yml up -d"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^9.0.1",
    "@prisma/client": "^6.9.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "node-telegram-bot-api": "^0.66.0",
    "nodemon": "^3.1.10"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/node-telegram-bot-api": "^0.64.9",
    "dotenv": "^17.0.1",
    "prisma": "^6.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  }
}
