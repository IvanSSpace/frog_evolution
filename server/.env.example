# PostgreSQL — берётся из Neon.tech (Settings → Connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Порт (Render подставляет автоматически через переменную окружения)
PORT=3000

# Сгенерируй: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Токен от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

NODE_ENV=production

# URL задеплоенного клиента на Vercel (https://your-app.vercel.app)
CLIENT_URL=

# --- Admin Panel ---
# Super-admin login email
ADMIN_EMAIL=admin@example.com

# bcrypt hash of admin password (10 rounds)
# Generate: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=

# Admin panel CORS origin (e.g. https://admin.example.com)
# Set to * only in development
ADMIN_ORIGIN=*
